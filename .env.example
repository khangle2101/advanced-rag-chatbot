# ===========================================
# AI Internal Knowledge Assistant
# Environment Variables Configuration
# ===========================================

# ------------------------------------------
# API Configuration
# ------------------------------------------
# Your OpenAI API key (or compatible provider)
OPENAI_API_KEY=sk-your-api-key-here

# API endpoint URL (change for alternative providers)
# Default: https://api.openai.com/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# ------------------------------------------
# Model Selection
# ------------------------------------------
# Model for generating final answers (use your best model)
ANSWER_MODEL=gpt-4o

# Model for query rewriting (can use smaller/cheaper model)
REWRITE_MODEL=gpt-4o-mini

# Model for re-ranking chunks (can use smaller/cheaper model)
RERANK_MODEL=gpt-4o-mini

# Model for document chunking during ingestion
CHUNKING_MODEL=gpt-4o-mini

# ------------------------------------------
# Security
# ------------------------------------------
# Admin password for document management
# IMPORTANT: Change this in production!
ADMIN_PASSWORD=admin123
