# ===========================================
# AI Internal Knowledge Assistant
# Environment Variables Configuration
# ===========================================

# ------------------------------------------
# API Configuration
# ------------------------------------------
# Main provider key used by the Advanced RAG pipeline
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Optional: direct OpenAI key if you want to run the LangChain baseline with OpenAI instead
OPENAI_API_KEY=

# API endpoint URL
# OpenAI:     https://api.openai.com/v1
# OpenRouter: https://openrouter.ai/api/v1
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# ------------------------------------------
# Model Selection
# ------------------------------------------
# Model for generating final answers (use your best model)
ANSWER_MODEL=openai/gpt-4.1

# Model for query rewriting (can use smaller/cheaper model)
REWRITE_MODEL=openai/gpt-4.1-mini

# Model for re-ranking chunks (can use smaller/cheaper model)
RERANK_MODEL=openai/gpt-4.1-mini

# Model for document chunking during ingestion
CHUNKING_MODEL=openai/gpt-4.1

# Optional: model for the LangChain baseline answer step
LANGCHAIN_LLM_MODEL=openai/gpt-4.1-mini

# ------------------------------------------
# Security
# ------------------------------------------
# Admin password for document management
# Required to enable document management in the UI
ADMIN_PASSWORD=change-me-before-running
